{
  "version": 2,
  "builds": [
    {
      "src": "api/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/server.js"
    },
    {
      "src": "/admin/messages",
      "dest": "/api/server.js"
    },
    {
      "src": "/admin",
      "dest": "/api/server.js"
    },
    {
      "src": "/privacy",
      "dest": "/api/server.js"
    },
    {
      "src": "/terms",
      "dest": "/api/server.js"
    },
    {
      "src": "/contact",
      "dest": "/api/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/server.js"
    }
  ]
}
